
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Veiculo {
  id        Int     @id @default(autoincrement())
  marca     String
  modelo    String
  anoFabricacao  Int @map("ano_fabricacao")
  anoModelo  Int @map("ano_modelo")
  preco    Float
  placa String @unique
  cor String
  quilometragem Int
  status String @default("disponível")
  dataCadastro DateTime @default(now()) @map("data_cadastro")
  dataAtualizacao DateTime @updatedAt @map("data_atualizacao")
  vendas Venda[]

  @@map("veiculos")
}

model Vendedor {
  id        Int     @id @default(autoincrement())
  nome      String
  email     String  @unique
  cpf       String  @unique
  telefone  String
  ativo     Boolean @default(true)
  dataCadastro DateTime @default(now()) @map("data_cadastro")
  dataAtualizacao DateTime @updatedAt @map("data_atualizacao")
  vendas    Venda[]

  @@map("vendedores")
}

model Cliente {
  id        Int     @id @default(autoincrement())
  nome      String
  cpfCnpj   String  @unique @map("cpf_cnpj")
  email     String  @unique
  telefone  String
  dataCadastro DateTime @default(now()) @map("data_cadastro")
  vendas    Venda[]

  @@map("clientes")
}

model Venda {
  id        Int     @id @default(autoincrement())
  veiculoId Int     @unique  @map("veiculo_id")
  vendedorId Int    @map("vendedor_id")
  clienteId Int     @map("cliente_id")
  valorVenda     Decimal @db.Decimal(12, 2) @map("valor_venda")
  valorComissao  Decimal @db.Decimal(12, 2) @map("valor_comissao")
  dataVenda DateTime @default(now()) @map("data_venda")

  veiculo   Veiculo @relation(fields: [veiculoId], references: [id])
  vendedor  Vendedor @relation(fields: [vendedorId], references: [id])
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  @@map("vendas")
}